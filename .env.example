# Copie para .env e ajuste

# LLM: "ollama" (local) ou "gemini" (nuvem, free tier)
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5
OLLAMA_EMBED_MODEL=bge-m3

# Gemini (juiz RAGAS opcional) - https://ai.google.dev
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# RAGAS: juiz "ollama" (local, sem cota) ou "gemini" (free tier, cota baixa)
RAGAS_JUDGE=ollama
RAGAS_OLLAMA_MODEL=qwen2.5

# RAG
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=5

# Re-ranking (RF08): off por padrao (avaliacao mostrou que piora; baseline saturado)
RERANK=false
RERANK_CANDIDATES=15

# Upload (admin): tamanho maximo por arquivo, em MB
MAX_UPLOAD_MB=10

# Auth (projeto Seguro)
JWT_SECRET=troque-isto-por-uma-chave-longa-aleatoria
JWT_EXPIRE_MINUTES=15
MAX_LOGIN_ATTEMPTS=5

# Frontend -> Backend
ASSISTDOC_API=http://127.0.0.1:8001

# Caminhos
CHROMA_DIR=./chroma_db
STORAGE_DIR=./storage
DOCS_BASE_DIR=./docs_base
SQLITE_PATH=./assistdoc.db
